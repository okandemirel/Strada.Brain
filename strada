#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
PACKAGE_JSON="$ROOT_DIR/package.json"
DIST_ENTRY="$ROOT_DIR/dist/index.js"
SOURCE_ENTRY="$ROOT_DIR/src/index.ts"
MANAGED_BLOCK_START="# >>> Strada command >>>"
MANAGED_BLOCK_END="# <<< Strada command <<<"

escape_for_double_quotes() {
  printf '%s' "$1" | sed 's/[\\"]/\\&/g'
}

shell_quote() {
  printf '%q' "$1"
}

print_missing_node() {
  echo "Strada requires Node.js 20+."
  echo "Install Node.js, then run ./strada again."
}

ensure_source_checkout() {
  if ! command -v node >/dev/null 2>&1; then
    print_missing_node
    exit 1
  fi

  if ! command -v npm >/dev/null 2>&1; then
    echo "Strada requires npm so it can prepare the local checkout."
    exit 1
  fi

  if [ ! -f "$PACKAGE_JSON" ]; then
    echo "Could not find package.json in $ROOT_DIR"
    echo "Run this launcher from the Strada.Brain repository root."
    exit 1
  fi

  if [ ! -d "$ROOT_DIR/node_modules" ]; then
    echo "Preparing Strada dependencies..."
    (cd "$ROOT_DIR" && npm install)
  fi
}

ensure_prepared() {
  ensure_source_checkout
  if [ ! -f "$DIST_ENTRY" ]; then
    echo "Preparing Strada build..."
    (cd "$ROOT_DIR" && npm run bootstrap)
  fi
}

install_command() {
  local install_dir="${XDG_BIN_HOME:-$HOME/.local/bin}"
  local wrapper_path="$install_dir/strada"
  local alias_path="$install_dir/strada-brain"
  local escaped_root
  local escaped_install_dir
  local shell_name
  local profile_path
  local profile_dir
  local profile_updated="false"
  local self_command
  escaped_root="$(escape_for_double_quotes "$ROOT_DIR")"
  escaped_install_dir="$(escape_for_double_quotes "$install_dir")"
  shell_name="$(basename "${SHELL:-sh}")"
  self_command="$(shell_quote "$0")"

  mkdir -p "$install_dir"

  cat >"$wrapper_path" <<EOF
#!/bin/sh
exec "$escaped_root/strada" "\$@"
EOF
  chmod +x "$wrapper_path"
  cp "$wrapper_path" "$alias_path"
  chmod +x "$alias_path"

  case "$shell_name" in
    fish)
      profile_path="${XDG_CONFIG_HOME:-$HOME/.config}/fish/conf.d/strada.fish"
      ;;
    bash)
      if [ -f "$HOME/.bash_profile" ]; then
        profile_path="$HOME/.bash_profile"
      else
        profile_path="$HOME/.bashrc"
      fi
      ;;
    zsh)
      profile_path="${ZDOTDIR:-$HOME}/.zshrc"
      ;;
    *)
      profile_path="$HOME/.profile"
      ;;
  esac

  profile_dir="$(dirname "$profile_path")"
  mkdir -p "$profile_dir"

  if [ ! -f "$profile_path" ] || ! grep -Fq "$MANAGED_BLOCK_START" "$profile_path"; then
    if [ "$shell_name" = "fish" ]; then
      cat >>"$profile_path" <<EOF
$MANAGED_BLOCK_START
if not contains "$escaped_install_dir" \$PATH
    set -gx PATH "$escaped_install_dir" \$PATH
end
$MANAGED_BLOCK_END
EOF
    else
      cat >>"$profile_path" <<EOF
$MANAGED_BLOCK_START
case ":\$PATH:" in
  *:"$escaped_install_dir":*) ;;
  *) export PATH="$escaped_install_dir:\$PATH" ;;
esac
$MANAGED_BLOCK_END
EOF
    fi
    profile_updated="true"
  fi

  echo "Installed user-local Strada commands:"
  echo "  $wrapper_path"
  echo "  $alias_path"
  if [ "$profile_updated" = "true" ]; then
    echo "Updated shell profile:"
    echo "  $profile_path"
  else
    echo "Shell profile already contains the Strada PATH entry:"
    echo "  $profile_path"
  fi

  case ":${PATH:-}:" in
    *":$install_dir:"*)
      echo "Your current PATH already includes $install_dir"
      ;;
    *)
      echo ""
      echo "Open a new terminal to pick up the new PATH automatically."
      echo "If you want it in this shell immediately, run:"
      if [ "$shell_name" = "fish" ]; then
        echo "  source \"$profile_path\""
      else
        echo "  . \"$profile_path\""
      fi
      ;;
  esac

  echo ""
  echo "You can keep using this checkout immediately without changing directories:"
  echo "  $self_command setup"
  echo "  $self_command doctor"
}

should_run_from_source() {
  if [ "$#" -eq 0 ]; then
    return 0
  fi

  case "${1:-}" in
    setup|doctor|--help|-h|--version|-V)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

if [ "${1:-}" = "install-command" ]; then
  install_command
  exit 0
fi

cd "$ROOT_DIR"

if should_run_from_source "$@"; then
  ensure_source_checkout
  exec node --import tsx "$SOURCE_ENTRY" "$@"
fi

ensure_prepared
exec node "$DIST_ENTRY" "$@"
