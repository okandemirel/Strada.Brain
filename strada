#!/usr/bin/env bash
set -euo pipefail

NODE_BIN="${STRADA_NODE_PATH:-node}"
if ! command -v "$NODE_BIN" >/dev/null 2>&1; then
  echo "Strada requires Node.js 20+."
  echo "Install Node.js, then run ./strada again."
  exit 1
fi

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
exec "$NODE_BIN" "$ROOT_DIR/scripts/source-launcher.mjs" --wrapper-kind posix --wrapper-path "$ROOT_DIR/strada" "$@"
