# === Required ===
JWT_SECRET=          # Required. Generate with: openssl rand -hex 64
ANTHROPIC_API_KEY=   # Primary AI provider

# === Optional AI Providers ===
OPENAI_API_KEY=      # OpenAI fallback
DEEPSEEK_API_KEY=    # DeepSeek (api.deepseek.com)
GROQ_API_KEY=        # Groq (api.groq.com)
QWEN_API_KEY=        # Alibaba Qwen (dashscope.aliyuncs.com)
KIMI_API_KEY=        # Moonshot Kimi (api.moonshot.cn)
MINIMAX_API_KEY=     # MiniMax (api.minimax.chat)
MISTRAL_API_KEY=     # Mistral AI
TOGETHER_API_KEY=    # Together AI
FIREWORKS_API_KEY=   # Fireworks AI
GEMINI_API_KEY=      # Google Gemini
OLLAMA_BASE_URL=     # Ollama local (default: http://localhost:11434)
PROVIDER_CHAIN=      # Comma-separated fallback order, e.g. claude,kimi,deepseek

# === Slack Channel ===
SLACK_BOT_TOKEN=     # xoxb-... Bot token
SLACK_SIGNING_SECRET= # Signing secret from Slack app
SLACK_APP_TOKEN=     # xapp-... App-level token (for socket mode)
SLACK_SOCKET_MODE=true

# === Discord Channel ===
DISCORD_BOT_TOKEN=   # Discord bot token
DISCORD_CLIENT_ID=   # Discord application client ID

# === Telegram Channel ===
TELEGRAM_BOT_TOKEN=  # Bot token from @BotFather

# === WhatsApp Channel ===
WHATSAPP_SESSION_PATH=.whatsapp-session
WHATSAPP_ALLOWED_NUMBERS= # Comma-separated phone numbers

# === Dashboard ===
DASHBOARD_PORT=3001
DASHBOARD_ENABLED=true

# === Security ===
REQUIRE_MFA=false
ALLOWED_SLACK_WORKSPACES=  # Comma-separated workspace IDs
ALLOWED_SLACK_USER_IDS=    # Comma-separated user IDs

# === Browser Automation ===
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=30000
BROWSER_MAX_CONCURRENT=5

# === Rate Limiting ===
RATE_LIMIT_MESSAGES_PER_MINUTE=0  # 0 = unlimited
RATE_LIMIT_MESSAGES_PER_HOUR=0
RATE_LIMIT_TOKENS_PER_DAY=0
RATE_LIMIT_DAILY_BUDGET_USD=0
RATE_LIMIT_MONTHLY_BUDGET_USD=0

# === System ===
HOSTNAME=              # Server hostname for alert metadata (auto-detected if unset)

# === Logging ===
LOG_LEVEL=info
NODE_ENV=development

# === Strada Framework Dependencies ===
STRADA_CORE_REPO_URL=https://github.com/okandemirel/Strata.Core.git
STRADA_MODULES_REPO_URL=https://github.com/okandemirel/Strata.Modules.git
