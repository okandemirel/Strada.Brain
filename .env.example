# Strata Brain Configuration
# Copy this to .env and fill in your values

# ======================
# AI Providers (Primary)
# ======================
ANTHROPIC_API_KEY=sk-ant-...

# ======================
# Multi-Provider (Optional)
# ======================
# Set PROVIDER_CHAIN for fallback: tries each provider in order
# Available: claude, openai, deepseek, qwen, kimi, minimax, groq, mistral, together, fireworks, gemini, ollama
# PROVIDER_CHAIN=claude,deepseek,ollama
#
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# QWEN_API_KEY=sk-...
# KIMI_API_KEY=sk-...
# MINIMAX_API_KEY=...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=...
# TOGETHER_API_KEY=...
# FIREWORKS_API_KEY=...
# GEMINI_API_KEY=...

# ======================
# Telegram Bot
# ======================
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ======================
# Security
# ======================
# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_TELEGRAM_USER_IDS=123456789

# Require confirmation before file edits (true/false)
REQUIRE_EDIT_CONFIRMATION=true

# Read-only mode - no file modifications allowed
READ_ONLY_MODE=false

# ======================
# Project
# ======================
# Path to the Unity project root (containing Assets/ folder)
UNITY_PROJECT_PATH=/path/to/your/unity/project

# ======================
# Dashboard
# ======================
# Enable real-time monitoring dashboard at http://localhost:3100
# DASHBOARD_ENABLED=true
# DASHBOARD_PORT=3100

# ======================
# Memory
# ======================
# Enable persistent memory (project cache + conversation history)
MEMORY_ENABLED=true
# Directory for memory storage (relative to working directory)
MEMORY_DB_PATH=.strata-memory

# ======================
# Logging
# ======================
LOG_LEVEL=info
LOG_FILE=strata-brain.log
