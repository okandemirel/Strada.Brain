# =============================================================================
# Strata.Brain - Docker Environment Configuration
# =============================================================================
# Copy this to .env and fill in your values
# =============================================================================

# ======================
# AI Providers (Required)
# ======================
ANTHROPIC_API_KEY=sk-ant-...

# ======================
# Multi-Provider (Optional)
# ======================
# PROVIDER_CHAIN=claude,deepseek,groq
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# GROQ_API_KEY=gsk-...
# MISTRAL_API_KEY=...
# GEMINI_API_KEY=...

# ======================
# Telegram Bot (Required for Telegram)
# ======================
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ======================
# Discord Bot (Optional)
# ======================
# DISCORD_BOT_TOKEN=...

# ======================
# Slack Bot (Optional)
# ======================
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_APP_TOKEN=xapp-...
# SLACK_SOCKET_MODE=true

# ======================
# Security
# ======================
ALLOWED_TELEGRAM_USER_IDS=
ALLOWED_SLACK_WORKSPACES=
ALLOWED_SLACK_USER_IDS=
REQUIRE_EDIT_CONFIRMATION=true
READ_ONLY_MODE=false

# ======================
# Project
# ======================
UNITY_PROJECT_PATH=./project

# ======================
# Dashboard & Ports
# ======================
DASHBOARD_ENABLED=true
DASHBOARD_PORT=3100
METRICS_PORT=9090
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ======================
# Memory
# ======================
MEMORY_ENABLED=true

# ======================
# Logging
# ======================
LOG_LEVEL=info

# ======================
# Resource Limits
# ======================
CPU_LIMIT=2
MEMORY_LIMIT=2G
CPU_RESERVATION=0.5
MEMORY_RESERVATION=512M

# ======================
# Plugins (Optional)
# ======================
# PLUGINS_PATH=./plugins

# ======================
# SSL (Optional)
# ======================
SSL_CERT_PATH=./nginx/ssl

# ======================
# Grafana (Optional)
# ======================
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=changeme
# GRAFANA_PORT=3000
# GRAFANA_ROOT_URL=http://localhost:3000

# ======================
# Prometheus (Optional)
# ======================
# PROMETHEUS_PORT=9091
