# =============================================================================
# Strata.Brain - Docker Ignore
# =============================================================================
# Files and directories to exclude from Docker build context
# This reduces build time and image size
# =============================================================================

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes
.gitmodules

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
*.md
!README.md
!SECURITY.md
docs/
CONTRIBUTING.md
CHANGELOG.md
LICENSE

# -----------------------------------------------------------------------------
# Node.js / npm
# -----------------------------------------------------------------------------
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist
build
coverage
.nyc_output
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Environment & Configuration
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.security.example
.env.local
.env.development
.env.test
.env.production

# -----------------------------------------------------------------------------
# IDE & Editor files
# -----------------------------------------------------------------------------
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
*.sublime-*
.project
.classpath
.settings/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
tests/
__tests__/
*.test.ts
*.test.js
*.spec.ts
*.spec.js
test/
tests/
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Security / Pentesting
# -----------------------------------------------------------------------------
pentest/
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
credentials/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.strata-memory/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
Dockerfile*
docker-compose*.yml
.docker/
.dockerignore
docker/
!docker/entrypoint.sh

# -----------------------------------------------------------------------------
# CI/CD
# -----------------------------------------------------------------------------
.github/
.gitlab-ci.yml
.travis.yml
.circleci/
.azure-pipelines.yml
Jenkinsfile

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
.cache/

# -----------------------------------------------------------------------------
# Project specific (Unity project should be mounted as volume)
# -----------------------------------------------------------------------------
project/
Assets/
Packages/
ProjectSettings/
*.unity
*.csproj
*.sln

# -----------------------------------------------------------------------------
# Backup files
# -----------------------------------------------------------------------------
*.bak
*.backup
*~
.bkp/

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.pid
*.seed
*.pid.lock
.eslintcache
.stylelintcache
.prettiercache
