{
  "dashboard": {
    "id": null,
    "title": "Strata Brain Metrics",
    "tags": ["strata", "brain", "ai", "unity"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "5s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "templating": {
      "list": []
    },
    "annotations": {
      "list": [
        {
          "name": "Annotations & Alerts",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "showLine": true,
          "iconColor": "rgba(255, 96, 96, 1)",
          "lineColor": "rgba(255, 96, 96, 0.6)",
          "enable": true,
          "query": "strata_messages_total"
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Messages Rate",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "rate(strata_messages_total[5m])",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "msg/s",
            "min": 0,
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "opacity"
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "success" },
              "properties": [
                { "id": "color", "value": { "fixed": "green" } }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "error" },
              "properties": [
                { "id": "color", "value": { "fixed": "red" } }
              ]
            }
          ]
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "calcs": ["mean", "max"]
          },
          "tooltip": { "mode": "multi" }
        }
      },
      {
        "id": 2,
        "title": "Active Sessions",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "strata_active_sessions",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 10 },
                { "color": "red", "value": 50 }
              ]
            }
          }
        },
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "justifyMode": "center"
        }
      },
      {
        "id": 3,
        "title": "Plugins Loaded",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "strata_plugins_loaded",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "blue", "value": null }
              ]
            }
          }
        },
        "options": {
          "graphMode": "none",
          "colorMode": "value"
        }
      },
      {
        "id": 4,
        "title": "Token Usage",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "rate(strata_tokens_total{type=\"input\"}[5m])",
            "legendFormat": "Input Tokens/s",
            "refId": "A"
          },
          {
            "expr": "rate(strata_tokens_total{type=\"output\"}[5m])",
            "legendFormat": "Output Tokens/s",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "tok/s",
            "min": 0,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Input Tokens/s" },
              "properties": [
                { "id": "color", "value": { "fixed": "#3fb950" } }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "Output Tokens/s" },
              "properties": [
                { "id": "color", "value": { "fixed": "#f85149" } }
              ]
            }
          ]
        },
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        }
      },
      {
        "id": 5,
        "title": "Total Token Usage",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "sum(increase(strata_tokens_total{type=\"total\"}[1h]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 10000 },
                { "color": "red", "value": 50000 }
              ]
            }
          }
        },
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        }
      },
      {
        "id": 6,
        "title": "Memory Usage",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "strata_memory_usage_bytes{type=\"rss\"}",
            "legendFormat": "RSS",
            "refId": "A"
          },
          {
            "expr": "strata_memory_usage_bytes{type=\"heap_used\"}",
            "legendFormat": "Heap Used",
            "refId": "B"
          },
          {
            "expr": "strata_memory_usage_bytes{type=\"heap_total\"}",
            "legendFormat": "Heap Total",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "min": 0,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 0
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        }
      },
      {
        "id": 7,
        "title": "Tool Duration",
        "type": "heatmap",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "rate(strata_tool_duration_seconds_bucket[5m])",
            "format": "heatmap",
            "legendFormat": "{{le}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "scaleDistribution": {
                "type": "log",
                "log": 2
              }
            }
          }
        },
        "options": {
          "calculate": false,
          "yAxis": {
            "unit": "s",
            "decimals": 2
          },
          "tooltip": {
            "show": true,
            "mode": "single"
          }
        }
      },
      {
        "id": 8,
        "title": "Tool Calls by Tool",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "rate(strata_tool_calls_total[5m])",
            "legendFormat": "{{tool}} - {{status}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "min": 0,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "stacking": { "mode": "normal" }
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "calcs": ["mean"]
          }
        }
      },
      {
        "id": 9,
        "title": "LLM Latency",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(strata_llm_latency_seconds_bucket[5m])) by (le, provider))",
            "legendFormat": "p50 - {{provider}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(strata_llm_latency_seconds_bucket[5m])) by (le, provider))",
            "legendFormat": "p95 - {{provider}}",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(strata_llm_latency_seconds_bucket[5m])) by (le, provider))",
            "legendFormat": "p99 - {{provider}}",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "min": 0,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 0
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        }
      },
      {
        "id": 10,
        "title": "Message Duration",
        "type": "heatmap",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "rate(strata_message_duration_seconds_bucket[5m])",
            "format": "heatmap",
            "legendFormat": "{{le}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "scaleDistribution": {
                "type": "log",
                "log": 2
              }
            }
          }
        },
        "options": {
          "calculate": false,
          "yAxis": {
            "unit": "s",
            "decimals": 0
          }
        }
      },
      {
        "id": 11,
        "title": "Tool Errors",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "rate(strata_tool_errors_total[5m])",
            "legendFormat": "{{tool}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "min": 0,
            "color": {
              "mode": "fixed",
              "fixedColor": "red"
            },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 20
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right"
          }
        }
      },
      {
        "id": 12,
        "title": "Node.js Event Loop Lag",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "targets": [
          {
            "expr": "nodejs_eventloop_lag_seconds",
            "legendFormat": "Event Loop Lag",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "min": 0,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "hidden"
          }
        }
      }
    ]
  },
  "overwrite": true,
  "folderUid": null,
  "message": "Strata Brain Metrics Dashboard"
}
