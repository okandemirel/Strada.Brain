{
  "name": "strada-brain",
  "version": "0.1.0",
  "description": "AI-powered Unity development assistant for Strada.Core framework projects",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && rm -rf dist/channels/web/static && cp -r src/channels/web/static dist/channels/web/static",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "security:audit": "npm audit --audit-level=high",
    "security:full": "./pentest/scripts/run-all-tests.sh",
    "security:critical": "./pentest/scripts/run-all-tests.sh --critical-only",
    "security:sast": "./pentest/scripts/test-sast.sh",
    "security:path": "./pentest/scripts/test-path-traversal.sh",
    "security:shell": "./pentest/scripts/test-command-injection.sh",
    "security:ssrf": "./pentest/scripts/test-ssrf.sh"
  },
  "keywords": [
    "unity",
    "ai",
    "telegram",
    "strata",
    "game-development",
    "ecs",
    "mvcs"
  ],
  "author": "Strata Brain Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@slack/bolt": "^4.6.0",
    "@slack/types": "^2.20.0",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "croner": "^10.0.1",
    "diff": "^8.0.3",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.0",
    "glob": "^11.0.0",
    "grammy": "^1.35.0",
    "hnswlib-node": "^3.0.0",
    "playwright": "^1.58.2",
    "prom-client": "^15.1.3",
    "winston": "^3.17.0",
    "ws": "^8.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.19.13",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
