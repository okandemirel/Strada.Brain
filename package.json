{
  "name": "strada-brain",
  "version": "4.2.76",
  "description": "AI-powered Unity development assistant for Strada.Core framework projects",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "scripts/source-launcher.mjs",
    "README.md",
    "README.tr.md",
    "README.de.md",
    "README.es.md",
    "README.fr.md",
    "README.ja.md",
    "README.ko.md",
    "README.zh.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "icon",
    "strada.js"
  ],
  "bin": {
    "strada": "./dist/index.js",
    "strada-brain": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "bootstrap": "npm install --prefix web-portal && npm run build",
    "doctor": "node --import tsx src/index.ts doctor",
    "setup:web": "node --import tsx src/index.ts setup --web",
    "setup:terminal": "node --import tsx src/index.ts setup --terminal",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run",
    "build": "node scripts/build-package.mjs",
    "build:portal": "npm --prefix web-portal run build",
    "lint:src": "eslint src/",
    "lint:portal": "npm --prefix web-portal run lint",
    "typecheck:src": "tsc --noEmit",
    "typecheck:portal": "npm --prefix web-portal run typecheck",
    "start": "node dist/index.js",
    "lint": "npm run lint:src && npm run lint:portal",
    "typecheck": "npm run typecheck:src && npm run typecheck:portal",
    "test": "node scripts/run-vitest-batches.mjs",
    "test:portal": "npm --prefix web-portal run test",
    "sync:check": "node --import tsx src/index.ts sync --dry-run",
    "test:file-build-flow": "LOCAL_DOTNET_TESTS=1 NODE_OPTIONS=--max-old-space-size=8192 vitest run src/tests/integration/file-build-flow.test.ts",
    "test:unity-fixture": "LOCAL_UNITY_FIXTURE_TESTS=1 NODE_OPTIONS=--max-old-space-size=8192 vitest run src/tests/integration/strada-unity-fixture.test.ts",
    "test:hnsw-perf": "HNSW_PERF_TESTS=1 NODE_OPTIONS=--max-old-space-size=8192 vitest run src/rag/hnsw/hnsw-performance.test.ts",
    "test:watch": "vitest",
    "smoke:cli:release": "node scripts/release/cli-release-smoke.mjs",
    "security:audit": "npm audit --audit-level=high",
    "security:full": "./pentest/scripts/run-all-tests.sh",
    "security:critical": "./pentest/scripts/run-all-tests.sh --critical-only",
    "security:sast": "./pentest/scripts/test-sast.sh",
    "security:path": "./pentest/scripts/test-path-traversal.sh",
    "security:shell": "./pentest/scripts/test-command-injection.sh",
    "security:ssrf": "./pentest/scripts/test-ssrf.sh"
  },
  "keywords": [
    "unity",
    "ai",
    "telegram",
    "strada",
    "game-development",
    "ecs",
    "mvcs"
  ],
  "author": "Strada.Brain Team",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@slack/bolt": "^4.6.0",
    "@slack/types": "^2.20.0",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "croner": "^10.0.1",
    "diff": "^8.0.3",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.0",
    "glob": "^11.0.0",
    "grammy": "^1.35.0",
    "picomatch": "^4.0.3",
    "playwright": "^1.58.2",
    "prom-client": "^15.1.3",
    "tree-sitter-c-sharp": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "tsx": "^4.19.0",
    "web-tree-sitter": "^0.25.10",
    "winston": "^3.17.0",
    "winston-transport": "^4.9.0",
    "ws": "^8.19.0",
    "xxhashjs": "^0.2.2",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.4.0",
    "hnswlib-node": "^3.0.0",
    "wavefile": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.19.13",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.16.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
